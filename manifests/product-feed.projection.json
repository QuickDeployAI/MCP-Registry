{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:product-feed",
  "importerVersionRange": "^0.1.0",
  "select": {
    "corpusGlobs": [
      "/releases/**",
      "/blog/**"
    ]
  },
  "auth": [],
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "refreshMinutes": {
          "type": "number",
          "description": "Refresh interval for the feed cache."
        },
        "maxItems": {
          "type": "number",
          "description": "Maximum feed items retained in the corpus."
        },
        "includeContent": {
          "type": "boolean",
          "description": "Whether full feed content is exposed in resources."
        }
      }
    },
    "defaults": {
      "refreshMinutes": 30,
      "maxItems": 100,
      "includeContent": true
    }
  },
  "expose": {
    "tools": [
      {
        "from": "corpus.search",
        "name": "search_product_feed"
      }
    ],
    "resources": [
      {
        "from": "feed:item",
        "name": "product_feed_item"
      }
    ]
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {},
    "configSchema": {
      "type": "object",
      "properties": {
        "refreshMinutes": {
          "type": "number"
        },
        "maxItems": {
          "type": "number"
        },
        "includeContent": {
          "type": "boolean"
        }
      }
    }
  }
}
