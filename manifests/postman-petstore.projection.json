{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:postman-petstore",
  "importerVersionRange": "^0.1.0",
  "select": {
    "requests": [
      {
        "method": "get",
        "uriTemplate": "/pets/{petId}"
      },
      {
        "method": "post",
        "uriTemplate": "/pets"
      }
    ]
  },
  "auth": [
    {
      "type": "bearer",
      "valueFrom": {
        "env": "PETSTORE_API_TOKEN"
      }
    },
    {
      "type": "api-key",
      "valueFrom": {
        "env": "PETSTORE_API_KEY"
      }
    }
  ],
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "baseUrl": {
          "type": "string",
          "description": "Base URL for collection requests."
        },
        "variables": {
          "type": "object",
          "description": "Non-secret Postman variable overrides."
        },
        "requestTimeoutMs": {
          "type": "number",
          "description": "Per-request upstream timeout in milliseconds."
        }
      }
    },
    "defaults": {
      "baseUrl": "https://petstore.example/v1",
      "variables": {
        "defaultStatus": "available"
      },
      "requestTimeoutMs": 30000
    }
  },
  "expose": {
    "tools": [
      {
        "from": "GET /pets/{petId}",
        "name": "postman_get_pet"
      },
      {
        "from": "POST /pets",
        "name": "postman_create_pet"
      }
    ]
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "baseUrl": {
        "type": "string",
        "description": "Base URL for collection requests."
      }
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "baseUrl": {
          "type": "string"
        }
      }
    }
  }
}
