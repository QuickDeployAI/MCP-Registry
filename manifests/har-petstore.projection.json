{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:har-petstore",
  "importerVersionRange": "^0.1.0",
  "select": {
    "requests": [
      {
        "method": "get",
        "uriTemplate": "/pet/{petId}"
      },
      {
        "method": "post",
        "uriTemplate": "/pet"
      }
    ]
  },
  "auth": [],
  "config": {
    "schema": {
      "type": "object",
      "required": [
        "baseUrl"
      ],
      "properties": {
        "baseUrl": {
          "type": "string",
          "description": "Base URL for reviewed HAR replay."
        },
        "redactionPolicy": {
          "type": "string",
          "description": "Redaction policy applied before publication."
        },
        "includeMethods": {
          "type": "array",
          "description": "HTTP methods retained from the capture."
        },
        "requestTimeoutMs": {
          "type": "number",
          "description": "Per-request upstream timeout."
        }
      }
    },
    "defaults": {
      "baseUrl": "https://petstore3.swagger.io/api/v3",
      "redactionPolicy": "strict",
      "includeMethods": [
        "GET",
        "POST"
      ],
      "requestTimeoutMs": 5000
    }
  },
  "expose": {
    "tools": [
      {
        "from": "GET /pet/{petId}",
        "name": "har_get_pet"
      },
      {
        "from": "POST /pet",
        "name": "har_create_pet"
      }
    ]
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "baseUrl": {
        "type": "string",
        "description": "Base URL for reviewed HAR replay."
      }
    },
    "configSchema": {
      "type": "object",
      "required": [
        "baseUrl"
      ],
      "properties": {
        "baseUrl": {
          "type": "string"
        }
      }
    }
  }
}
