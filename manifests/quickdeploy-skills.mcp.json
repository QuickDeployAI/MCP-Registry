{
  "apiVersion": "quickdeploy.ai/v1",
  "kind": "McpManifest",
  "metadata": {
    "name": "ai.quickdeploy/skills",
    "version": "0.1.0",
    "title": "QuickDeploy Skills",
    "description": "Curated QuickDeploy Agent Skills exposed as MCP prompts.",
    "labels": [
      "agent-skills",
      "quickdeploy",
      "skills"
    ]
  },
  "spec": {
    "importer": {
      "engine": "agent-skills-2-mcp",
      "versionRange": "^0.1.0"
    },
    "source": {
      "type": "git",
      "uri": "git+https://github.com/QuickDeployAI/agent-skills.git#main"
    },
    "select": {
      "skills": [
        {
          "name": "agentic-eval",
          "globs": [
            "agentic-eval/**"
          ]
        },
        {
          "name": "playwright-cli",
          "globs": [
            "playwright-cli/**"
          ]
        }
      ]
    },
    "auth": [],
    "expose": {
      "tools": [
        {
          "from": "playwright/run",
          "name": "browser_run"
        },
        {
          "from": "browser/install-extension",
          "deny": true,
          "reason": "Extension installation is not safe for hosted execution."
        }
      ],
      "prompts": [
        {
          "from": "agentic-eval/design-eval",
          "name": "design_agentic_eval"
        }
      ]
    }
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "workspaceRoot": {
        "type": "string",
        "description": "Workspace root passed to the skills runtime."
      }
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "type": "string"
        }
      }
    }
  }
}
