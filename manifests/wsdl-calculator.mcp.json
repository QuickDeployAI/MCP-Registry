{
  "apiVersion": "quickdeploy.ai/v1",
  "kind": "McpManifest",
  "metadata": {
    "name": "ai.quickdeploy/wsdl-calculator",
    "version": "0.1.0",
    "title": "WSDL Calculator Fixture",
    "description": "Document-literal SOAP calculator exposed through wsdl-2-mcp.",
    "labels": [
      "wsdl",
      "soap",
      "fixture"
    ]
  },
  "spec": {
    "importer": {
      "engine": "wsdl-2-mcp",
      "versionRange": "^0.1.0"
    },
    "source": {
      "type": "file",
      "uri": "file://packages/importers/wsdl-2-mcp/fixtures/calculator-document-literal.wsdl"
    },
    "select": {
      "requests": [
        {
          "method": "post",
          "uriTemplate": "/soap/CalculatorService/Add"
        }
      ]
    },
    "auth": [],
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string",
            "description": "SOAP endpoint override for the selected service port."
          },
          "bindingName": {
            "type": "string",
            "description": "Optional WSDL binding name when multiple bindings are present."
          },
          "requestTimeoutMs": {
            "type": "number",
            "description": "Per-request SOAP timeout in milliseconds."
          }
        }
      },
      "defaults": {
        "endpoint": "https://example.invalid/soap/calculator",
        "requestTimeoutMs": 30000
      }
    },
    "expose": {
      "tools": [
        {
          "from": "POST /soap/CalculatorService/Add",
          "name": "calculator_add"
        }
      ]
    }
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "endpoint": {
        "type": "string",
        "description": "SOAP endpoint override for hosted runtime use."
      }
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "endpoint": {
          "type": "string"
        }
      }
    }
  }
}
