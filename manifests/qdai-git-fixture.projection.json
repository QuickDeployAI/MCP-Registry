{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:qdai-git-fixture",
  "importerVersionRange": "^0.1.0",
  "select": {
    "pythonFunctions": [
      "qdai_git_fixture.*"
    ]
  },
  "auth": [],
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "packageRoot": {
          "type": "string",
          "description": "Materialized checkout path for the pinned git source."
        }
      }
    }
  },
  "expose": {
    "tools": [
      {
        "from": "qdai_git_fixture.add",
        "name": "fixture_add"
      },
      {
        "from": "qdai_git_fixture.slugify",
        "name": "fixture_slugify"
      },
      {
        "from": "qdai_git_fixture.summarize",
        "name": "fixture_summarize"
      },
      {
        "from": "qdai_git_fixture.guess_kind",
        "name": "fixture_guess_kind"
      },
      {
        "from": "qdai_git_fixture.TextTools.initials",
        "name": "fixture_text_initials"
      },
      {
        "from": "qdai_git_fixture.TextTools.repeat",
        "name": "fixture_text_repeat"
      }
    ]
  },
  "deployment": {
    "transport": "stdio",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "packageRoot": {
        "type": "string",
        "description": "Materialized checkout path for the pinned git source."
      }
    }
  }
}
