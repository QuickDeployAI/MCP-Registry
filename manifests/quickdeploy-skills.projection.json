{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:skills",
  "importerVersionRange": "^0.1.0",
  "select": {
    "skills": [
      {
        "name": "agentic-eval",
        "globs": [
          "agentic-eval/**"
        ]
      },
      {
        "name": "playwright-cli",
        "globs": [
          "playwright-cli/**"
        ]
      }
    ]
  },
  "auth": [],
  "expose": {
    "tools": [
      {
        "from": "playwright/run",
        "name": "browser_run"
      },
      {
        "from": "browser/install-extension",
        "deny": true,
        "reason": "Extension installation is not safe for hosted execution."
      }
    ],
    "prompts": [
      {
        "from": "agentic-eval/design-eval",
        "name": "design_agentic_eval"
      }
    ]
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "workspaceRoot": {
        "type": "string",
        "description": "Workspace root passed to the skills runtime."
      }
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "type": "string"
        }
      }
    }
  }
}
