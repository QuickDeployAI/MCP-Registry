{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quickdeploy.ai/schemas/servers-json.schema.json",
  "title": "QuickDeploy servers.json",
  "description": "An array or envelope of verbatim MCP server.json documents. QuickDeploy curation lives only in reverse-DNS _meta keys.",
  "oneOf": [
    {
      "type": "array",
      "items": { "$ref": "#/$defs/server" }
    },
    {
      "type": "object",
      "required": ["servers"],
      "properties": {
        "$schema": { "type": "string" },
        "generatedAt": { "type": "string" },
        "servers": {
          "type": "array",
          "items": { "$ref": "#/$defs/server" }
        },
        "_meta": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  ],
  "$defs": {
    "server": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "$schema": {
          "type": "string",
          "pattern": "(2025-09-29|2025-12-11)"
        },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "packages": {
          "type": "array",
          "items": { "$ref": "#/$defs/package" }
        },
        "remotes": {
          "type": "array",
          "items": { "$ref": "#/$defs/remote" }
        },
        "environmentVariables": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentVariable" }
        },
        "_meta": { "$ref": "#/$defs/meta" }
      },
      "not": {
        "anyOf": [
          { "required": ["verifiedStatus"] },
          { "required": ["verified_status"] },
          { "required": ["category"] },
          { "required": ["isOfficial"] },
          { "required": ["is_official"] },
          { "required": ["isPaid"] },
          { "required": ["is_paid"] },
          { "required": ["tags"] },
          { "required": ["quickdeploy"] },
          { "required": ["quickDeploy"] },
          { "required": ["curation"] },
          { "required": ["manifest"] }
        ]
      },
      "additionalProperties": true
    },
    "package": {
      "type": "object",
      "required": ["registryType"],
      "properties": {
        "registryType": { "type": "string", "minLength": 1 },
        "identifier": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "runtimeHint": { "type": "string", "minLength": 1 },
        "transport": { "type": "string", "minLength": 1 },
        "runtimeArguments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environmentVariables": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "remote": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "headers": {
          "type": "array",
          "items": { "type": "object" }
        },
        "variables": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "environmentVariable": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "isRequired": { "type": "boolean" },
        "isSecret": { "type": "boolean" },
        "default": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "properties": {
        "ai.quickdeploy.registry/curation": {
          "$ref": "#/$defs/curation"
        },
        "ai.quickdeploy.registry/manifest": {}
      },
      "patternProperties": {
        "^ai\\.quickdeploy\\.registry/": {}
      },
      "additionalProperties": true
    },
    "curation": {
      "type": "object",
      "properties": {
        "verifiedStatus": {
          "enum": ["unverified", "verified", "review", "deprecated", "blocked"],
          "default": "unverified"
        },
        "category": { "type": "string", "minLength": 1 },
        "isOfficial": { "type": "boolean" },
        "isPaid": { "type": "boolean" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      },
      "additionalProperties": false
    }
  }
}
