{
  "apiVersion": "quickdeploy.ai/v1",
  "kind": "McpManifest",
  "metadata": {
    "name": "ai.quickdeploy/qdai-git-fixture",
    "version": "1.0.0",
    "title": "QuickDeployAI Git Fixture",
    "description": "git-2-mcp dogfood example, every lib method of a small Python package as a tool.",
    "labels": [
      "git",
      "python",
      "example"
    ]
  },
  "spec": {
    "importer": {
      "engine": "git-2-mcp",
      "versionRange": "^0.1.0"
    },
    "source": {
      "type": "git",
      "uri": "git+https://github.com/QuickDeployAI/git-2-mcp-fixture.git@0123456789abcdef0123456789abcdef01234567"
    },
    "select": {
      "pythonFunctions": [
        "qdai_git_fixture.*"
      ]
    },
    "auth": [],
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "packageRoot": {
            "type": "string",
            "description": "Materialized checkout path for the pinned git source."
          }
        }
      }
    },
    "expose": {
      "tools": [
        {
          "from": "qdai_git_fixture.add",
          "name": "fixture_add"
        },
        {
          "from": "qdai_git_fixture.slugify",
          "name": "fixture_slugify"
        },
        {
          "from": "qdai_git_fixture.summarize",
          "name": "fixture_summarize"
        },
        {
          "from": "qdai_git_fixture.guess_kind",
          "name": "fixture_guess_kind"
        },
        {
          "from": "qdai_git_fixture.TextTools.initials",
          "name": "fixture_text_initials"
        },
        {
          "from": "qdai_git_fixture.TextTools.repeat",
          "name": "fixture_text_repeat"
        }
      ]
    }
  },
  "deployment": {
    "transport": "stdio",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "packageRoot": {
        "type": "string",
        "description": "Materialized checkout path for the pinned git source."
      }
    }
  }
}
