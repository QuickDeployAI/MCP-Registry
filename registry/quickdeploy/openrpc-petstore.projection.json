{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:openrpc-petstore",
  "importerVersionRange": "^0.1.0",
  "select": {
    "methods": ["pets.get"]
  },
  "expose": {
    "tools": [
      {
        "from": "pets.get",
        "name": "get_pet"
      }
    ],
    "resources": [],
    "prompts": []
  },
  "auth": [],
  "config": {
    "schema": {
      "type": "object",
      "required": ["endpoint"],
      "properties": {
        "endpoint": {
          "type": "string",
          "description": "JSON-RPC endpoint used by the generated OpenRPC tools."
        },
        "transport": {
          "type": "string",
          "description": "JSON-RPC transport: http or ws."
        },
        "requestTimeoutMs": {
          "type": "number"
        }
      }
    },
    "defaults": {
      "endpoint": "https://rpc.example.test",
      "transport": "http",
      "requestTimeoutMs": 30000
    }
  },
  "deployment": {
    "transport": "stdio",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "endpoint": {
        "type": "string",
        "description": "JSON-RPC endpoint override."
      }
    }
  }
}
