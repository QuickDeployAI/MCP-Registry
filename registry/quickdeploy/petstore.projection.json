{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:petstore",
  "importerVersionRange": "^0.1.0",
  "select": {
    "requests": [
      {
        "method": "get",
        "uriTemplate": "/pet/{petId}"
      },
      {
        "method": "post",
        "uriTemplate": "/pet"
      }
    ]
  },
  "auth": [
    {
      "type": "bearer",
      "valueFrom": {
        "env": "PETSTORE_API_TOKEN"
      }
    }
  ],
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "baseUrl": {
          "type": "string"
        }
      }
    },
    "defaults": {
      "baseUrl": "https://petstore3.swagger.io/api/v3"
    }
  },
  "expose": {
    "tools": [
      {
        "from": "GET /pet/{petId}",
        "name": "get_pet"
      },
      {
        "from": "POST /pet",
        "name": "create_pet"
      }
    ]
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "baseUrl": {
        "type": "string",
        "description": "Petstore API base URL."
      }
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "baseUrl": {
          "type": "string"
        }
      }
    }
  }
}
