{
  "apiVersion": "quickdeploy.ai/v1",
  "kind": "McpManifest",
  "metadata": {
    "name": "ai.quickdeploy/postman-petstore",
    "version": "0.1.0",
    "title": "Postman Petstore",
    "description": "Postman Collection requests exposed as MCP tools.",
    "labels": [
      "postman",
      "openapi",
      "petstore"
    ]
  },
  "spec": {
    "importer": {
      "engine": "postman-2-mcp",
      "versionRange": "^0.1.0"
    },
    "source": {
      "type": "file",
      "uri": "file://packages/importers/postman-2-mcp/fixtures/petstore-collection.json"
    },
    "select": {
      "requests": [
        {
          "method": "get",
          "uriTemplate": "/pets/{petId}"
        },
        {
          "method": "post",
          "uriTemplate": "/pets"
        }
      ]
    },
    "auth": [
      {
        "type": "bearer",
        "valueFrom": {
          "env": "PETSTORE_API_TOKEN"
        }
      },
      {
        "type": "api-key",
        "valueFrom": {
          "env": "PETSTORE_API_KEY"
        }
      }
    ],
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "baseUrl": {
            "type": "string",
            "description": "Base URL for collection requests."
          },
          "variables": {
            "type": "object",
            "description": "Non-secret Postman variable overrides."
          },
          "requestTimeoutMs": {
            "type": "number",
            "description": "Per-request upstream timeout in milliseconds."
          }
        }
      },
      "defaults": {
        "baseUrl": "https://petstore.example/v1",
        "variables": {
          "defaultStatus": "available"
        },
        "requestTimeoutMs": 30000
      }
    },
    "expose": {
      "tools": [
        {
          "from": "GET /pets/{petId}",
          "name": "postman_get_pet"
        },
        {
          "from": "POST /pets",
          "name": "postman_create_pet"
        }
      ]
    }
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "baseUrl": {
        "type": "string",
        "description": "Base URL for collection requests."
      }
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "baseUrl": {
          "type": "string"
        }
      }
    }
  }
}
