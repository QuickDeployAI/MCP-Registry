{
  "apiVersion": "quickdeploy.ai/v1",
  "kind": "McpManifest",
  "metadata": {
    "name": "ai.quickdeploy/har-petstore",
    "version": "0.1.0",
    "title": "HAR Petstore Fixture",
    "description": "Reviewed Petstore HAR capture exposed through har-2-mcp.",
    "labels": [
      "har",
      "petstore"
    ]
  },
  "spec": {
    "importer": {
      "engine": "har-2-mcp",
      "versionRange": "^0.1.0"
    },
    "source": {
      "type": "file",
      "uri": "file://packages/importers/har-2-mcp/fixtures/petstore.har"
    },
    "select": {
      "requests": [
        {
          "method": "get",
          "uriTemplate": "/pet/{petId}"
        },
        {
          "method": "post",
          "uriTemplate": "/pet"
        }
      ]
    },
    "auth": [],
    "config": {
      "schema": {
        "type": "object",
        "required": [
          "baseUrl"
        ],
        "properties": {
          "baseUrl": {
            "type": "string",
            "description": "Base URL for reviewed HAR replay."
          },
          "redactionPolicy": {
            "type": "string",
            "description": "Redaction policy applied before publication."
          },
          "includeMethods": {
            "type": "array",
            "description": "HTTP methods retained from the capture."
          },
          "requestTimeoutMs": {
            "type": "number",
            "description": "Per-request upstream timeout."
          }
        }
      },
      "defaults": {
        "baseUrl": "https://petstore3.swagger.io/api/v3",
        "redactionPolicy": "strict",
        "includeMethods": [
          "GET",
          "POST"
        ],
        "requestTimeoutMs": 5000
      }
    },
    "expose": {
      "tools": [
        {
          "from": "GET /pet/{petId}",
          "name": "har_get_pet"
        },
        {
          "from": "POST /pet",
          "name": "har_create_pet"
        }
      ]
    }
  },
  "deployment": {
    "transport": "streamable-http",
    "auth": {
      "type": "none"
    },
    "userConfig": {
      "baseUrl": {
        "type": "string",
        "description": "Base URL for reviewed HAR replay."
      }
    },
    "configSchema": {
      "type": "object",
      "required": [
        "baseUrl"
      ],
      "properties": {
        "baseUrl": {
          "type": "string"
        }
      }
    }
  }
}
