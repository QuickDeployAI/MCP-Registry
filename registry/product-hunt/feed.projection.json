{
  "kind": "McpProjectionConfig",
  "entryRef": "urn:air:quickdeploy.ai:mcp:product-hunt",
  "importerVersionRange": "^0.1.0",
  "select": {
    "requests": [],
    "grpcMethods": [],
    "pythonFunctions": [],
    "skills": [],
    "knowledgeSources": [],
    "corpusGlobs": [
      "/products/**"
    ],
    "workflows": []
  },
  "expose": {
    "tools": [
      {
        "from": "feed.query",
        "name": "query_product_hunt_feed",
        "deny": false
      }
    ],
    "resources": [
      {
        "from": "feed:item",
        "name": "product_hunt_feed_item",
        "deny": false
