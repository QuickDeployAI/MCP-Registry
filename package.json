{
  "name": "@quickdeployai/mcp-registry-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "QuickDeployAI MCP Registry workspace",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check": "turbo run build typecheck lint test && pnpm registry:validate",
    "changeset": "changeset",
    "version:packages": "changeset version && pnpm registry:validate",
    "publish:packages": "pnpm registry:validate && changeset publish",
    "registry:validate": "pnpm --filter @quickdeployai/registry-cli registry:validate"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "@quickdeployai/registry-cli": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "supportedArchitectures": {
      "os": ["win32", "linux", "darwin"],
      "cpu": ["x64", "arm64"]
    }
  }
}
