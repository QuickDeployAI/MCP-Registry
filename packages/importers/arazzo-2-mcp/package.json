{
  "name": "@quickdeployai/arazzo-2-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Arazzo workflow artifact importer utilities for QuickDeployAI derived workflow capabilities.",
  "bin": {
    "arazzo-2-mcp": "./src/bin.mts"
  },
  "files": [
    "src",
    "fixtures",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sources": {
      "types": "./src/sources.ts",
      "import": "./src/sources.ts",
      "default": "./src/sources.ts"
    },
    "./runtime-expressions": {
      "types": "./src/runtime-expressions.ts",
      "import": "./src/runtime-expressions.ts",
      "default": "./src/runtime-expressions.ts"
    },
    "./success-criteria": {
      "types": "./src/success-criteria.ts",
      "import": "./src/success-criteria.ts",
      "default": "./src/success-criteria.ts"
    },
    "./runner": {
      "types": "./src/runner.ts",
      "import": "./src/runner.ts",
      "default": "./src/runner.ts"
    },
    "./tools": {
      "types": "./src/tools.ts",
      "import": "./src/tools.ts",
      "default": "./src/tools.ts"
    }
  },
  "scripts": {
    "start": "tsx src/bin.mts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@quickdeployai/importer-core": "workspace:*",
    "@quickdeployai/proxy-core": "workspace:*",
    "@quickdeployai/registry-schemas": "workspace:*",
    "openapi-types": "^12.1.3",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
