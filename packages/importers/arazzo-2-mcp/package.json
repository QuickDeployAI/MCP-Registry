{
  "name": "@quickdeployai/arazzo-2-mcp",
  "version": "0.1.0",
  "description": "Standalone Arazzo workflow to MCP server.",
  "bin": {
    "arazzo-2-mcp": "./dist/bin.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "fixtures",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sources": {
      "types": "./dist/sources.d.ts",
      "default": "./dist/sources.js"
    },
    "./runtime-expressions": {
      "types": "./dist/runtime-expressions.d.ts",
      "default": "./dist/runtime-expressions.js"
    },
    "./success-criteria": {
      "types": "./dist/success-criteria.d.ts",
      "default": "./dist/success-criteria.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "default": "./dist/runner.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    }
  },
  "scripts": {
    "start": "node dist/bin.mjs serve",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && vitest run",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@quickdeployai/importer-core": "workspace:*",
    "@quickdeployai/proxy-core": "workspace:*",
    "openapi-types": "^12.1.3",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
