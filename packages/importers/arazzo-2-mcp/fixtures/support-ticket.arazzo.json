{
  "arazzo": "1.0.1",
  "info": {
    "title": "Support Ticket Workflow",
    "version": "1.2.0",
    "description": "Create and triage a customer support ticket."
  },
  "sourceDescriptions": [
    {
      "name": "support-api",
      "type": "openapi3",
      "url": "https://api.example.test/openapi.json"
    }
  ],
  "workflows": [
    {
      "workflowId": "create-and-triage-ticket",
      "summary": "Create and triage ticket",
      "description": "Creates a ticket, adds customer context, and assigns triage.",
      "inputs": {
        "type": "object",
        "properties": {
          "customerId": { "type": "string" },
          "message": { "type": "string" }
        },
        "required": ["customerId", "message"]
      },
      "steps": [
        {
          "stepId": "create-ticket",
          "description": "Create the ticket record.",
          "operationId": "createTicket",
          "parameters": {
            "customerId": "$inputs.customerId"
          },
          "successCriteria": [
            {
              "condition": "$statusCode == 201"
            }
          ]
        },
        {
          "stepId": "assign-ticket",
          "description": "Assign the ticket to first-line support.",
          "operationId": "assignTicket",
          "dependsOn": ["create-ticket"]
        }
      ],
      "outputs": {
        "ticketId": "$steps.create-ticket.response.body.id"
      }
    }
  ]
}
