{
  "name": "@quickdeployai/api-manifest-2-mcp",
  "version": "0.1.0",
  "description": "Standalone Microsoft API Manifest to MCP server.",
  "bin": {
    "api-manifest-2-mcp": "./dist/bin.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && vitest run",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/bin.mjs serve"
  },
  "dependencies": {
    "@quickdeployai/importer-core": "workspace:*",
    "@quickdeployai/proxy-core": "workspace:*",
    "@quickdeployai/registry-schemas": "workspace:*",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
