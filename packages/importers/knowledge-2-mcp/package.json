{
  "name": "@quickdeployai/knowledge-2-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing a self-hosted document corpus (markdown trees, OpenWiki output) as searchable, citable tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "knowledge-2-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuickDeployAI/MCP-Registry.git",
    "directory": "packages/importers/knowledge-2-mcp"
  },
  "dependencies": {
    "@quickdeployai/corpus-core": "workspace:*",
    "@quickdeployai/importer-core": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "^4.19.3",
    "typescript": "catalog:",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=22.18"
  }
}
