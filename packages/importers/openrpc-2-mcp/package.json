{
  "name": "@quickdeployai/openrpc-2-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "OpenRPC to MCP importer utilities.",
  "bin": {
    "openrpc-2-mcp": "./src/bin.mts"
  },
  "files": [
    "src",
    "fixtures",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@open-rpc/meta-schema": "^1.14.9",
    "@open-rpc/schema-utils-js": "^2.2.1",
    "@quickdeployai/importer-core": "workspace:*",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
