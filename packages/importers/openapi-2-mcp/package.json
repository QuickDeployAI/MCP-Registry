{
  "name": "@quickdeployai/openapi-2-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Build an MCP (Model Context Protocol) server from an OpenAPI spec. Exposes every API operation as an MCP tool so AI agents can interact with any REST API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuickDeployAI/MCP-Registry.git",
    "directory": "packages/importers/openapi-2-mcp"
  },
  "keywords": [
    "mcp",
    "openapi",
    "model-context-protocol",
    "ai",
    "tools",
    "api"
  ],
  "author": "QuickDeployAI",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/QuickDeployAI/MCP-Registry/issues"
  },
  "homepage": "https://github.com/QuickDeployAI/MCP-Registry/tree/main/packages/importers/openapi-2-mcp#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@quickdeployai/importer-core": "workspace:*",
    "@quickdeployai/proxy-core": "workspace:*",
    "@quickdeployai/registry-schemas": "workspace:*",
    "@readme/openapi-parser": "^6.0.0",
    "commander": "^14.0.3",
    "openapi-types": "^12.1.3",
    "swagger2openapi": "^7.0.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "catalog:",
    "@types/swagger2openapi": "^7.0.4",
    "js-yaml": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "bin": {
    "openapi-2-mcp": "./dist/cli.js"
  }
}
