<?xml version="1.0" encoding="UTF-8"?>
<definitions
  xmlns="http://schemas.xmlsoap.org/wsdl/"
  xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns:tns="https://quickdeploy.ai/fixtures/wsdl/legacy-rpc"
  targetNamespace="https://quickdeploy.ai/fixtures/wsdl/legacy-rpc"
  name="LegacyInventoryService">
  <message name="LookupInventoryInput">
    <part name="sku" type="xsd:string"/>
    <part name="warehouse" type="xsd:string"/>
  </message>
  <message name="LookupInventoryOutput">
    <part name="available" type="xsd:boolean"/>
    <part name="quantity" type="xsd:int"/>
  </message>

  <portType name="LegacyInventoryPortType">
    <operation name="LookupInventory">
      <input message="tns:LookupInventoryInput"/>
      <output message="tns:LookupInventoryOutput"/>
    </operation>
  </portType>

  <binding name="LegacyInventorySoapBinding" type="tns:LegacyInventoryPortType">
    <soap:binding style="rpc" transport="http://schemas.xmlsoap.org/soap/http"/>
    <operation name="LookupInventory">
      <soap:operation soapAction="urn:LegacyInventory#LookupInventory"/>
      <input>
        <soap:body
          use="encoded"
          namespace="urn:LegacyInventory"
          encodingStyle="http://schemas.xmlsoap.org/soap/encoding/"/>
      </input>
      <output>
        <soap:body
          use="encoded"
          namespace="urn:LegacyInventory"
          encodingStyle="http://schemas.xmlsoap.org/soap/encoding/"/>
      </output>
    </operation>
  </binding>

  <service name="LegacyInventoryService">
    <port name="LegacyInventorySoapPort" binding="tns:LegacyInventorySoapBinding">
      <soap:address location="https://example.invalid/soap/legacy-inventory"/>
    </port>
  </service>
</definitions>
