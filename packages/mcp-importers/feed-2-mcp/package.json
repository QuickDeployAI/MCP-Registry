{
  "name": "@quickdeployai/feed-2-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for RSS/Atom feed querying",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "feed-2-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuickDeployAI/MCP-Registry.git",
    "directory": "packages/mcp-importers/feed-2-mcp"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "catalog:",
    "commander": "^14.0.3",
    "feedsmith": "^2.9.0",
    "node-html-parser": "^7.1.0",
    "openai": "^6.27.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "^4.19.3",
    "typescript": "catalog:",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=22.18"
  }
}
