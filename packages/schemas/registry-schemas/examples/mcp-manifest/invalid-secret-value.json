{
  "apiVersion": "quickdeploy.ai/v1",
  "kind": "McpManifest",
  "metadata": {
    "name": "ai.quickdeploy/raw-secret",
    "version": "1.0.0"
  },
  "spec": {
    "importer": {
      "engine": "openapi-2-mcp",
      "versionRange": "^0.1.0"
    },
    "source": {
      "type": "http",
      "uri": "https://api.example.com/openapi.json"
    },
    "select": {
      "requests": [
        {
          "method": "GET",
          "uriTemplate": "/users"
        }
      ]
    },
    "auth": [
      {
        "type": "bearer",
        "value": "sk-test-plaintext"
      }
    ]
  },
  "deployment": {
    "transport": "streamable-http"
  }
}
