{
  "apiVersion": "quickdeploy.ai/v1",
  "kind": "McpManifest",
  "metadata": {
    "name": "ai.quickdeploy/agent-skills",
    "version": "0.1.0",
    "title": "Agent Skills",
    "description": "Curated agent skills exposed as MCP tools and prompts.",
    "labels": ["skills", "agent"]
  },
  "spec": {
    "importer": {
      "engine": "agent-skills-2-mcp",
      "versionRange": "^0.1.0"
    },
    "source": {
      "type": "git",
      "uri": "git+https://github.com/QuickDeployAI/agent-skills.git",
      "ref": "main"
    },
    "select": {
      "skills": [
        {
          "name": "agentic-eval",
          "globs": ["agentic-eval/**"]
        },
        {
          "name": "playwright-cli",
          "globs": ["playwright-cli/**"]
        }
      ]
    },
    "expose": {
      "tools": [
        {
          "from": "playwright/run",
          "name": "browser_run"
        },
        {
          "from": "browser/install-extension",
          "deny": true,
          "reason": "Extension installation is not safe for hosted execution."
        }
      ],
      "prompts": [
        {
          "from": "agentic-eval/design-eval",
          "name": "design_agentic_eval"
        }
      ]
    }
  },
  "deployment": {
    "transport": "stdio",
    "userConfig": {
      "workspaceRoot": {
        "type": "string",
        "description": "Workspace root passed to the skills runtime."
      }
    },
    "configSchema": {
      "type": "object",
      "required": ["workspaceRoot"],
      "properties": {
        "workspaceRoot": {
          "type": "string"
        }
      }
    }
  }
}
