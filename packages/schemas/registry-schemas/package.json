{
  "name": "@quickdeployai/registry-schemas",
  "version": "0.1.0",
  "private": true,
  "description": "Shared MCP registry schemas consumed from source by Vite/tsc — no build step.",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mcp-manifest": {
      "types": "./src/mcp-manifest.ts",
      "import": "./src/mcp-manifest.ts",
      "default": "./src/mcp-manifest.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "ajv": "^8.17.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
