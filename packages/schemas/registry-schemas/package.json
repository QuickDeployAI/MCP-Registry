{
  "name": "@quickdeployai/registry-schemas",
  "version": "0.1.0",
  "description": "Published registry and capability schemas used by MCP importers and clients.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ard": {
      "types": "./dist/ard.d.ts",
      "default": "./dist/ard.js"
    },
    "./inference": {
      "types": "./dist/inference.d.ts",
      "default": "./dist/inference.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./mcp-manifest": {
      "types": "./dist/mcp-manifest.d.ts",
      "default": "./dist/mcp-manifest.js"
    },
    "./mcp-projection": {
      "types": "./dist/mcp-projection.d.ts",
      "default": "./dist/mcp-projection.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "ajv": "^8.17.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
