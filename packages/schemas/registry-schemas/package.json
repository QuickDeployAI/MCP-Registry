{
  "name": "@quickdeployai/registry-schemas",
  "version": "0.1.0",
  "private": true,
  "description": "Shared registry + capability schemas, listing DTOs, manifest inference, and a typed client for the registries edge function. Consumed from source by Vite/tsc — no build step.",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./inference": {
      "types": "./src/inference.ts",
      "import": "./src/inference.ts",
      "default": "./src/inference.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./mcp-manifest": {
      "types": "./src/mcp-manifest.ts",
      "import": "./src/mcp-manifest.ts",
      "default": "./src/mcp-manifest.ts"
    },
    "./mcp-projection": {
      "types": "./src/mcp-projection.ts",
      "import": "./src/mcp-projection.ts",
      "default": "./src/mcp-projection.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "ajv": "^8.17.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
