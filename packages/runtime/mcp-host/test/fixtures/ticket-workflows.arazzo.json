    {
      "workflowId": "close-ticket",
      "inputs": {
        "type": "object",
        "properties": { "ticketId": { "type": "string" } },
        "required": ["ticketId"]
      },
      "steps": [{ "stepId": "close", "operationId": "closeTicket" }]
    }
  ]
}
