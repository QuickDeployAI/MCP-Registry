{
  "name": "@quickdeployai/registry-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Build QuickDeploy MCP servers.json and legacy registry/index.json artifacts.",
  "bin": {
    "registry-cli": "./src/cli.mts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "start": "tsx src/cli.mts",
    "build:registry": "tsx src/cli.mts build",
    "check:generated": "tsx src/cli.mts build --check",
    "validate": "tsx src/cli.mts validate",
    "registry:validate": "tsx src/cli.mts validate",
    "validate:remotes": "tsx src/cli.mts validate-remotes",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --testTimeout=30000"
  },
  "dependencies": {
    "@quickdeployai/importer-core": "workspace:*",
    "@quickdeployai/registry-schemas": "workspace:*",
    "yaml": "^2.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@quickdeployai/mcp-host": "workspace:*",
    "@types/node": "^24.13.2",
    "tsx": "catalog:",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
