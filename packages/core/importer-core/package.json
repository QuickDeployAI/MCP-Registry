{
  "name": "@quickdeployai/importer-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared runtime helpers for QuickDeployAI MCP importers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./bindings": {
      "types": "./dist/bindings.d.ts",
      "default": "./dist/bindings.js"
    },
    "./json-rpc": {
      "types": "./dist/json-rpc.d.ts",
      "default": "./dist/json-rpc.js"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "default": "./dist/parser.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "tsc -p tsconfig.build.json && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@microsoft/mxc-sdk": "^0.7.0"
  },
  "devDependencies": {
    "@quickdeployai/mcp-registry-workspace-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
