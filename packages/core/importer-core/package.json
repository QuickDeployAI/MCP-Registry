{
  "name": "@quickdeployai/importer-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared runtime helpers for QuickDeployAI MCP importers",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
