{
  "name": "@quickdeployai/importer-core",
  "version": "0.1.0",
  "description": "Shared runtime helpers for QuickDeployAI MCP importers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "tsc -p tsconfig.build.json && node --test test/*.test.mjs"
  },
  "devDependencies": {
    "@quickdeployai/mcp-registry-workspace-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
